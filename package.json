{
	"name": "@techtrips/ui-controls",
	"module": "lib/index.js",
	"types": "lib/index.d.ts",
	"version": "0.1.1",
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"lib",
		"LICENSE",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"default": "./lib/index.js"
		},
		"./themes/light.css": "./lib/themes/light.css",
		"./themes/dark.css": "./lib/themes/dark.css",
		"./themes/auto.css": "./lib/themes/auto.css",
		"./themes/fluent.css": "./lib/themes/fluent.css",
		"./themes/material.css": "./lib/themes/material.css",
		"./themes/index.css": "./lib/themes/index.css",
		"./themes/*": "./lib/themes/*"
	},
	"scripts": {
		"clean": "rimraf lib",
		"build": "npm run clean && tsc -p tsconfig.prod.json && node scripts/copy-css.js",
		"dev": "rspack dev",
		"lint": "biome check .",
		"format": "biome format .",
		"lint-fix": "npx biome check . --write",
		"versionpatch": "npm version patch",
		"postversion": "node scripts/postversion.js && git add README.md docs/ChangeLog.md && git commit --amend --no-edit",
		"publishpackage": "npm publish --access public"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@fluentui/react-components": "^9.73.8",
		"@fluentui/react-icons": "^2.0.325",
		"@mui/icons-material": "^9.0.0",
		"@mui/material": "^9.0.0",
		"@rspack/cli": "^1.7.10",
		"@rspack/core": "^1.7.10",
		"@rspack/plugin-react-refresh": "^1.6.0",
		"@types/react": "^19.2.8",
		"@types/react-dom": "^19.2.3",
		"process": "^0.11.10",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-refresh": "^0.18.0",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/techtrips/ui-controls.git"
	},
	"keywords": [
		"ui-controls",
		"react-ui-controls",
		"ui-controls-react",
		"ui-react-controls",
		"react-common-controls",
		"react-composite-controls",
		"composite-controls",
		"composite-ui-controls",
		"react-composite-ui-controls",
		"datagrid",
		"react-datagrid",
		"data-grid",
		"react-data-grid",
		"data-table",
		"react-data-table",
		"grid",
		"table",
		"sortable-table",
		"filterable-table",
		"groupable-table",
		"paginated-table",
		"techtrips",
		"techtrips-ui",
		"techtrips-ui-controls",
		"techtrips-react-ui-controls"
	],
	"license": "MIT",
	"author": "TechTrips",
	"description": "A React composite UI controls library — DataGrid and more, headless core with opt-in plugins"
}
