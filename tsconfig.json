{
	"compilerOptions": {
		"lib": ["DOM", "ES2020"],
		"jsx": "react-jsx",
		"target": "ES2020",
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"skipLibCheck": true,
		"useDefineForClassFields": true,
		"allowJs": true,
		"outDir": "lib",

		/* modules */
		"module": "ESNext",
		"moduleDetection": "force",
		"moduleResolution": "bundler",
		"verbatimModuleSyntax": false,
		"resolveJsonModule": true,
		"allowImportingTsExtensions": false,
		"noUncheckedSideEffectImports": true,

		/* type checking */
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,

		/* path aliases — let the playground & examples import the library
		 * by its published name so example files double as copy-paste-ready
		 * source for consumers. */
		"baseUrl": ".",
		"paths": {
			"@techtrips/ui-controls": ["src/index.ts"]
		}
	},
	"include": ["src", "examples"]
}
